{
  "text-overflow: ellipsis": {
    "prefix": "3toe",
    "body": [
      "cursor: pointer;",
      "line-height: 20px;",
      "margin-left: 8px;",
      "overflow: hidden;",
      "text-overflow: ellipsis;",
      "word-break: break-all;",
