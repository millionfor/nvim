  "vue3 typescript setup": {
    "prefix": "vue3",
    "body": [
      "<template>",
      "  <div :class=\"classes\">",
      "    $TM_FILENAME_BASE",
      "  </div>",
      "</template>",
      "",
      "<script setup lang=\"ts\">",
      "  import { computed } from 'vue';",
      "",
      "  const prefixCls = 'vi-$TM_FILENAME_BASE'",
      "  const classes = computed(() => { return [\\`${ prefixCls }\\`] })",
      "",
      "</script>",
      "<style lang=\"scss\" >",
      "  $-prefix-cls: 'vi-$TM_FILENAME_BASE';",
      "  .#{$-prefix-cls} {",
