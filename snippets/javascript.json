  "Promise.withResolvers()": {
    "prefix": "pror",
    "body": [
      "const { promise, resolve, reject } = Promise.withResolvers()",
      "",
      "setTimeout(() => {",
      "\tresolve('Success!');",
      "}, 1000);",
      "",
      "promise.then(value => {",
      "\tconsole.log(value); // \"Success!\"",
      "});"
    ],
    "description": "Promise.withResolvers()"
  },
